{
  "name": "shreyasislocked",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "vite",
    "build": "bun run build:wasm && bun run copy:deps && vite build",
    "build:wasm": "cd rust-search && wasm-pack build --target web --out-dir ../src/lib/wasm --release",
    "build:server": "cargo build --release --bin server",
    "copy:deps": "bun scripts/copy-deps.ts",
    "preview": "vite preview",
    "serve": "bun run build && bun run build:server && ./target/release/server",
    "start": "./target/release/server",
    "dev:proxy": "cargo run --release --bin server"
  },
  "devDependencies": {
    "vite": "^6.0.3",
    "typescript": "^5.7.2",
    "unplugin-swc": "^1.5.1",
    "@swc/core": "^1.10.1"
  },
  "dependencies": {
    "@mercuryworkshop/bare-as-module3": "^2.2.5",
    "@mercuryworkshop/bare-mux": "^2.1.8",
    "@titaniumnetwork-dev/ultraviolet": "^3.2.10",
    "motion": "^12.38.0"
  }
}
